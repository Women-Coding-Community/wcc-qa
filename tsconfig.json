{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "paths": {
      "helpers/*": ["./helpers/*"]
    },
    "types": ["node"]
  },
  "include": ["tests/**/*.ts", "helpers/**/*.ts", "playwright.config.ts"]
}
