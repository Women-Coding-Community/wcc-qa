{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["helpers/api/*"],
      "@pages/*": ["helpers/pages/*"],
      "@auth/*": ["helpers/auth/*"],
      "@data/*": ["helpers/data/*"],
      "@preconditions/*": ["helpers/preconditions/*"],
      "@fixtures": ["helpers/fixtures/index.ts"],
      "@fixtures/*": ["helpers/fixtures/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "test-results", "playwright-report"]
}
