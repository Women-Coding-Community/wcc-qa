{
	"name": "wcc-qa",
	"version": "1.0.0",
	"main": "index.js",
	"scripts": {
		"test": "playwright test",
		"test:api": "playwright test --project=api",
		"test:admin": "playwright test --project=admin",
		"typecheck": "tsc --noEmit",
		"report": "playwright show-report",
		"lint": "eslint helpers tests playwright.config.ts",
		"lint:fix": "eslint --fix helpers tests playwright.config.ts",
		"format": "prettier --check helpers tests playwright.config.ts",
		"format:fix": "prettier --write helpers tests playwright.config.ts",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,mjs,js}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.58.2",
		"@types/node": "^25.5.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-playwright": "^2.10.4",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.8.4",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.61.1"
	},
	"dependencies": {
		"@faker-js/faker": "^10.4.0",
		"dotenv": "^17.3.1",
		"zod": "^4.3.6"
	}
}
